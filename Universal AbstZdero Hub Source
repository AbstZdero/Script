--[ESP Logic (Runs after physics/rendering frame)]
RunService.RenderStepped:Connect(function()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local char = player.Character

            -- Ensure drawing object exists for the player
            if not ESP_Boxes[player] then
                local box = Drawing.new("Square")
                box.Visible = false
                box.Color = ESP_SETTINGS.HighlightColor
                box.Thickness = 1.5
                box.Filled = false
                ESP_Boxes[player] = box
            end

            local box = ESP_Boxes[player]
            
            -- Ensure player has a character and is alive
            if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
                
                -- 1. Handling Player Highlights
                local highlight = char:FindFirstChild("AbstZdero_Highlight")
                if ESP_SETTINGS.Players then
                    if not highlight then
                        highlight = Instance.new("Highlight")
                        highlight.Name = "AbstZdero_Highlight"
                        highlight.Parent = char
                    end
                    -- Apply dynamically chosen colors and transparencies
                    highlight.FillColor = ESP_SETTINGS.HighlightColor
                    highlight.OutlineColor = ESP_SETTINGS.HighlightColor
                    highlight.FillTransparency = ESP_SETTINGS.FillTransparency
                    highlight.OutlineTransparency = ESP_SETTINGS.OutlineTransparency
                else
                    if highlight then highlight:Destroy() end
                end

                -- 2. Handling 2D ESP Box
                if ESP_SETTINGS.Box then
                    local rootPart = char.HumanoidRootPart
                    local rootPos, onScreen = Camera:WorldToViewportPoint(rootPart.Position)

                    if onScreen then
                        -- Calculate standard top and bottom character points to form an accurate box
                        local topPos = Camera:WorldToViewportPoint(rootPart.Position + Vector3.new(0, 3, 0))
                        local bottomPos = Camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, 3.5, 0))

                        local height = math.abs(topPos.Y - bottomPos.Y)
                        local width = height * 0.6 -- Average avatar aspect ratio

                        box.Size = Vector2.new(width, height)
                        box.Position = Vector2.new(rootPos.X - (width / 2), topPos.Y)
                        box.Color = ESP_SETTINGS.HighlightColor
                        box.Visible = true
                    else
                        box.Visible = false
                    end
                else
                    box.Visible = false
                end

                -- 3. Handling Names, Studs, and Health (Text ESP)
                local head = char:FindFirstChild("Head")
                if head then
                    local bgui = head:FindFirstChild("AbstZdero_TextESP")
                    
                    if ESP_SETTINGS.Names or ESP_SETTINGS.Studs or ESP_SETTINGS.Health then
                        if not bgui then
                            bgui = Instance.new("BillboardGui")
                            bgui.Name = "AbstZdero_TextESP"
                            bgui.Parent = head
                            bgui.Size = UDim2.new(0, 200, 0, 50)
                            bgui.StudsOffset = Vector3.new(0, 3, 0)
                            bgui.AlwaysOnTop = true

                            local textLabel = Instance.new("TextLabel")
                            textLabel.Parent = bgui
                            textLabel.Size = UDim2.new(1, 0, 1, 0)
                            textLabel.BackgroundTransparency = 1
                            textLabel.TextStrokeTransparency = 0.2 -- Small black outline for visibility
                            textLabel.Font = Enum.Font.Code
                            textLabel.TextSize = 14
                        end

                        local textLabel = bgui.TextLabel
                        textLabel.TextColor3 = ESP_SETTINGS.TextColor

                        local displayText = ""
                        
                        -- Add Name
                        if ESP_SETTINGS.Names then
                            displayText = displayText .. player.Name .. "\n"
                        end
                        
                        -- Add Studs
                        if ESP_SETTINGS.Studs and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                            local distance = (LocalPlayer.Character.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude
                            displayText = displayText .. "[" .. math.floor(distance) .. " Studs]\n"
                        end
                        
                        -- Add Health
                        if ESP_SETTINGS.Health then
                            displayText = displayText .. "[HP: " .. math.floor(char.Humanoid.Health) .. "/" .. math.floor(char.Humanoid.MaxHealth) .. "]"
                        end
                        
                        textLabel.Text = displayText
                    else
                        -- Destroy the text GUI if none of the text options are toggled
                        if bgui then bgui:Destroy() end
                    end
                end
            else
                -- If dead/despawned, clean up Drawings
                if box then box.Visible = false end
            end
        end
    end
end)


--[Player Logic (Runs before physics simulate to prevent stutters for things like Noclip)]
RunService.Stepped:Connect(function()
    local char = LocalPlayer.Character

    -- Loop Walkspeed Logic
    if PLAYER_SETTINGS.LoopWalkspeed and char then
        local humanoid = char:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.WalkSpeed = PLAYER_SETTINGS.WalkspeedValue
        end
    end

    -- Noclip Logic
    if PLAYER_SETTINGS.Noclip and char then
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") and part.CanCollide == true then
                part.CanCollide = false
            end
        end
    end
end)

-- [Infinite Jump Logic]
UserInputService.JumpRequest:Connect(function()
    if PLAYER_SETTINGS.InfiniteJump and LocalPlayer.Character then
        local humanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
        if humanoid and humanoid.Health > 0 then
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end
end)
